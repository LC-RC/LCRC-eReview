# LCRC eReview - ignore local/config and generated files

# Environment and config (often contain secrets)
.env
.env.local
.env.*.local
config/*_config.php
!config/recaptcha_config.example.php

# OpenAI key for support chat (optional local override)
includes/chat_openai.local.php

# IDE and OS
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs and temp
*.log
tmp/
temp/
cache/

# Composer (if you use it later)
/vendor/

# Node dependencies (tracked so collaborators don't need npm install)
# node_modules/

# User uploads (tracked so collaborators get the folder; avoid very large files)
# uploads/
